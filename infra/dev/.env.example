# CERNIQ — dev compose env template.
# Copy to infra/dev/.env and fill in. NEVER commit .env.
# These values are dev-only — do not promote them to prod.

# Postgres ─────────────────────────────────────────────────────────
# WARNING: trivial default. Use only on localhost. Rotate before exposing.
POSTGRES_PASSWORD=devpassword

# Grafana ──────────────────────────────────────────────────────────
# WARNING: change immediately after first login.
GF_SECURITY_ADMIN_PASSWORD=admin

# CERNIQ audit-signing public key ──────────────────────────────────
# Generate with: pnpm --filter @cerniq/scripts run keys
# Copy the CERNIQ_SIGNING_PUBLIC_KEY value from .local/keys/cerniq-signing.env here.
# The API will refuse to boot if this is unset (no silent fallback).
CERNIQ_SIGNING_PUBLIC_KEY=

# Optional — when the key was rotated. ISO 8601. The /.well-known/ endpoint
# uses this for cache headers. Defaults to 2026-01-01T00:00:00Z if unset.
CERNIQ_SIGNING_KEY_ROTATED_AT=2026-01-01T00:00:00Z
