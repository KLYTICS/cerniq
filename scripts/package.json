{
  "name": "@cerniq/scripts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CERNIQ operator scripts — keygen, dev seed, OpenAPI/Zod/Prisma parity check.",
  "bin": {
    "cerniq": "./cerniq-cli.ts"
  },
  "scripts": {
    "keys": "tsx generate-cerniq-keys.ts",
    "seed": "tsx seed-dev.ts",
    "verify-spec": "tsx verify-spec.ts",
    "cerniq": "tsx cerniq-cli.ts",
    "backtest-verify": "tsx backtest-verify.ts",
    "audit-verify-chain": "tsx audit-verify-chain.ts",
    "_comment_audit_retention": "audit-retention CLI moved to apps/api/scripts/run-audit-retention.ts in Round 17 — run via `pnpm --filter @cerniq/api run audit-retention`.",
    "encrypt-webhook-secrets": "tsx encrypt-existing-webhook-secrets.ts",
    "seed:demo": "tsx seed-demo.ts",
    "seed:demo:reset": "tsx seed-demo.ts --reset-only",
    "audit:errors": "tsx audit-error-catalog.ts",
    "doctor": "tsx doctor.ts",
    "doctor:full": "tsx doctor.ts --full",
    "bench:verify": "tsx benchmark-verify.ts",
    "db:index-audit": "tsx db-index-audit.ts",
    "gen:changelog": "tsx generate-changelog.ts",
    "publish:dry-run": "tsx publish-dry-run.ts",
    "publish:dry-run:all": "tsx publish-dry-run.ts --all",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cerniq/types": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "commander": "^12.1.0",
    "reflect-metadata": "^0.2.2",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cerniq/tsconfig": "workspace:*",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
