# ============================================================================
# AEGIS — Environment configuration
# ============================================================================
#
# Copy to `.env` (gitignored) and adjust per environment.
#
#   cp .env.example .env
#
# Convention:
#   • [DEV-OK]  has a sane default and works without setting in dev
#   • [REQUIRED-PROD]  must be set before booting in production (boot fails loud)
#   • [OPTIONAL]  enables a feature when set; absence ≠ broken
#
# Single source of truth for the schema is `apps/api/src/config/config.schema.ts`.
# If you add a new env var there, add it here too — `.env.example` is a contract,
# not a hint. Stale = broken onboarding.
# ============================================================================


# ── Runtime ────────────────────────────────────────────────────────────── DEV-OK
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug
API_BASE_URL=http://localhost:4000
CORS_ORIGINS=*


# ── Database & cache ──────────────────────────────────────────────── REQUIRED
# Provided automatically by `pnpm db:up` (docker-compose) for local dev.
DATABASE_URL=postgresql://aegis:aegis@localhost:5432/aegis?schema=public
REDIS_URL=redis://localhost:6379


# ── Crypto: signing keys ─────────────────────────────────────────── REQUIRED-PROD
# CLAUDE.md "one curve, one library" — every signing primitive is Ed25519
# (`@noble/ed25519`). Three independent keypairs (don't reuse):
#
#   AEGIS_SIGNING_*       — audit-event chain signing (publishes at /.well-known)
#   JWT_ED25519_*         — agent-policy capability JWT signing
#   AUDIT_ED25519_*_B64   — DEPRECATED alias for AEGIS_SIGNING_*; keep until v0.2
#
# Generate locally:
#   pnpm tsx scripts/generate-aegis-keys.ts
#
# Production: keys MUST live in your KMS (see AEGIS_KMS_PROVIDER below) — these
# env vars are the development fallback only.

AEGIS_SIGNING_PRIVATE_KEY=
AEGIS_SIGNING_PUBLIC_KEY=
# ISO 8601 — when the active signing key was last rotated. Surfaces in
# /.well-known/audit-signing-key for downstream JWKS consumers.
AEGIS_SIGNING_KEY_ROTATED_AT=

JWT_ED25519_PRIVATE_KEY_B64=
JWT_ED25519_PUBLIC_KEY_B64=

# Legacy aliases — accepted with a deprecation warning. Remove after rename.
AUDIT_ED25519_PRIVATE_KEY_B64=
AUDIT_ED25519_PUBLIC_KEY_B64=
AUDIT_SIGNING_KEY_B64=


# ── Crypto: KMS provider ─────────────────────────────────────── REQUIRED-PROD
# Which KMS adapter to use for audit-chain signing.
#   in-memory  — generates a key at boot (DEV ONLY; refuses in prod)
#   aws        — AWS KMS envelope-encrypted Ed25519 (set AWS_REGION + wrapped key)
#   gcp        — Google Cloud KMS native EdDSA
#   vault      — HashiCorp Vault Transit
AEGIS_KMS_PROVIDER=in-memory

# AWS KMS — populate when AEGIS_KMS_PROVIDER=aws
AWS_REGION=
AEGIS_AWS_KMS_AUDIT_KID=
AEGIS_AWS_KMS_AUDIT_WRAPPED=
AEGIS_AWS_KMS_AUDIT_PUB=

# GCP KMS — populate when AEGIS_KMS_PROVIDER=gcp
AEGIS_GCP_KMS_AUDIT_KID=
AEGIS_GCP_KMS_AUDIT_RESOURCE=
AEGIS_GCP_KMS_AUDIT_PUB=

# Vault Transit — populate when AEGIS_KMS_PROVIDER=vault
AEGIS_VAULT_ADDR=
AEGIS_VAULT_TOKEN=
AEGIS_VAULT_AUDIT_KID=
AEGIS_VAULT_AUDIT_TRANSIT_NAME=
AEGIS_VAULT_AUDIT_VERSION=
AEGIS_VAULT_AUDIT_PUB=


# ── Crypto: webhook secret-at-rest ──────────────────────────── REQUIRED-PROD
# 32-byte AES-256-GCM data encryption key (base64). Wraps every
# `WebhookSubscription.secret` so a DB-only compromise cannot forge HMACs.
# Generate:  openssl rand -base64 32
# Production: REQUIRED — boot fails-loud if absent.
# Dev: optional — cipher logs an ephemeral DEK on first use.
AEGIS_WEBHOOK_SECRET_DEK_B64=


# ── Auth: API key bcrypt ──────────────────────────────────────────────── DEV-OK
# 12 in production, 4 in tests/CI for speed.
API_KEY_BCRYPT_COST=12


# ── Auth: federated identity (Auth0 / Clerk / WorkOS) ────────────── OPTIONAL
# Auth0 ADR-0009 bridge. Issuer matches Auth0 `iss` claim shape.
AUTH0_ISSUER=
AUTH0_AUDIENCE=
AUTH0_ACTION_SECRET=
# Set to 'true' to require an Auth0 session before serving the dashboard.
# Defaults to permitting all requests in dev so local development works
# without an Auth0 tenant.
AUTH0_REQUIRED=false


# ── Rate limits ──────────────────────────────────────────────────────── DEV-OK
# Per-minute caps (nest-throttler). Tune per plan tier in production.
THROTTLE_VERIFY_PER_MIN=1000
THROTTLE_DEFAULT_PER_MIN=120


# ── Feature flags ────────────────────────────────────────────────────── DEV-OK
ENABLE_BATE=true
ENABLE_WEBHOOKS=true
ENABLE_SWAGGER=true
# Require DPoP proof on every /v1/verify (RFC 9449). Off by default —
# turn on after rolling out client-side proof generation in the SDK.
AEGIS_DPOP_REQUIRED=false
# Enable post-quantum hybrid signatures (Ed25519 || ML-DSA-65). Scaffold-
# ready; flip on once your relying parties accept the larger sig payloads.
AEGIS_HYBRID_PQ_ENABLED=false
# Comma-separated list. Default is the in-process builtin engine.
# Add 'cedar' or 'opa' once the corresponding WASM artifact is shipping.
AEGIS_POLICY_ENGINES=builtin


# ── Observability: tracing (OpenTelemetry) ─────────────────────────── OPTIONAL
# When AEGIS_OTEL_ENABLED=true, the API emits W3C-compatible spans for the
# verify hot path, audit chain, KMS round-trips, and policy engine eval.
AEGIS_OTEL_ENABLED=false
AEGIS_OTEL_SERVICE_NAME=aegis-api
# Exporter: 'otlp-http' (production) | 'console' (debug) | 'noop'
AEGIS_OTEL_EXPORTER=otlp-http
# Standard OTel envs honored by the SDK:
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_RESOURCE_ATTRIBUTES=
# Optional: stamp deployment region on every span (e.g. us-east-1, eu-west-1).
AEGIS_REGION=


# ── Observability: errors + metrics ──────────────────────────────── OPTIONAL
# Sentry DSN — leave blank to disable error reporting.
SENTRY_DSN=


# ── Build identity (CI/release pipeline only) ─────────────────────── OPTIONAL
# Surfaced at GET /health/version for blue-green confirmation.
AEGIS_VERSION=
GIT_SHA=
BUILD_AT=


# ── Stripe billing (Phase 1 — M-011) ──────────────────────────────── OPTIONAL
# When STRIPE_SECRET_KEY is unset, BillingService is a no-op (manual
# planTier admin still works). When set, all six STRIPE_* vars below are
# required for `POST /v1/billing/checkout` to function.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Per-tier price ids from the Stripe dashboard.
# Tier names locked by ADR-0014 (2026-05-05): GROWTH renamed to TEAM,
# new SCALE tier added. Per-verify overage: $0.0008 uniform across
# paid tiers (Developer/Team/Scale).
STRIPE_PRICE_DEVELOPER=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_SCALE=
STRIPE_PRICE_ENTERPRISE=
# Optional metered usage product (per-verify overage). When set, usage
# records are reported to Stripe for billing on overage. Leave blank to
# hard-stop at tier cap with no overage.
STRIPE_PRICE_OVERAGE_VERIFY=
# Where Stripe-hosted Checkout / Customer Portal redirect after the user
# finishes (or cancels) the flow. Required when STRIPE_SECRET_KEY is set.
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=
STRIPE_PORTAL_RETURN_URL=


# ── Dashboard ─────────────────────────────────────────────────────────── DEV-OK
# Phase 1 dashboard is server-rendered and reads the API server-side. It
# uses an operator-pinned API key until per-user Auth0 sessions land (M-020).
NEXT_PUBLIC_API_URL=http://localhost:4000
AEGIS_DASHBOARD_API_KEY=
AEGIS_DASHBOARD_PRINCIPAL_ID=
# Override only when running the dashboard against a non-localhost API.
AEGIS_API_BASE_URL=
