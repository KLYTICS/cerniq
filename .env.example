# ============================================================================
# CERNIQ — Environment configuration
# ============================================================================
#
# Copy to `.env` (gitignored) and adjust per environment.
#
#   cp .env.example .env
#
# Convention:
#   • [DEV-OK]  has a sane default and works without setting in dev
#   • [REQUIRED-PROD]  must be set before booting in production (boot fails loud)
#   • [OPTIONAL]  enables a feature when set; absence ≠ broken
#
# Single source of truth for the schema is `apps/api/src/config/config.schema.ts`.
# If you add a new env var there, add it here too — `.env.example` is a contract,
# not a hint. Stale = broken onboarding.
# ============================================================================


# ── Runtime ────────────────────────────────────────────────────────────── DEV-OK
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug
API_BASE_URL=http://localhost:4000
CORS_ORIGINS=*


# ── Database & cache ──────────────────────────────────────────────── REQUIRED
# Provided automatically by `pnpm db:up` (docker-compose) for local dev.
DATABASE_URL=postgresql://cerniq:cerniq@localhost:5432/cerniq?schema=public
REDIS_URL=redis://localhost:6379


# ── Crypto: signing keys ─────────────────────────────────────────── REQUIRED-PROD
# CLAUDE.md "one curve, one library" — every signing primitive is Ed25519
# (`@noble/ed25519`). Three independent keypairs (don't reuse):
#
#   CERNIQ_SIGNING_*       — audit-event chain signing (publishes at /.well-known)
#   JWT_ED25519_*         — agent-policy capability JWT signing
#   AUDIT_ED25519_*_B64   — DEPRECATED alias for CERNIQ_SIGNING_*; keep until v0.2
#
# Generate locally:
#   pnpm tsx scripts/generate-cerniq-keys.ts
#
# Production: keys MUST live in your KMS (see CERNIQ_KMS_PROVIDER below) — these
# env vars are the development fallback only.

CERNIQ_SIGNING_PRIVATE_KEY=
CERNIQ_SIGNING_PUBLIC_KEY=
# ISO 8601 — when the active signing key was last rotated. Surfaces in
# /.well-known/audit-signing-key for downstream JWKS consumers.
CERNIQ_SIGNING_KEY_ROTATED_AT=

JWT_ED25519_PRIVATE_KEY_B64=
JWT_ED25519_PUBLIC_KEY_B64=

# Legacy aliases — accepted with a deprecation warning. Remove after rename.
AUDIT_ED25519_PRIVATE_KEY_B64=
AUDIT_ED25519_PUBLIC_KEY_B64=
AUDIT_SIGNING_KEY_B64=


# ── Crypto: KMS provider ─────────────────────────────────────── REQUIRED-PROD
# Which KMS adapter to use for audit-chain signing.
#   in-memory  — generates a key at boot (DEV ONLY; refuses in prod)
#   aws        — AWS KMS envelope-encrypted Ed25519 (set AWS_REGION + wrapped key)
#   gcp        — Google Cloud KMS native EdDSA
#   vault      — HashiCorp Vault Transit
CERNIQ_KMS_PROVIDER=in-memory

# AWS KMS — populate when CERNIQ_KMS_PROVIDER=aws
AWS_REGION=
CERNIQ_AWS_KMS_AUDIT_KID=
CERNIQ_AWS_KMS_AUDIT_WRAPPED=
CERNIQ_AWS_KMS_AUDIT_PUB=

# GCP KMS — populate when CERNIQ_KMS_PROVIDER=gcp
CERNIQ_GCP_KMS_AUDIT_KID=
CERNIQ_GCP_KMS_AUDIT_RESOURCE=
CERNIQ_GCP_KMS_AUDIT_PUB=

# Vault Transit — populate when CERNIQ_KMS_PROVIDER=vault
CERNIQ_VAULT_ADDR=
CERNIQ_VAULT_TOKEN=
CERNIQ_VAULT_AUDIT_KID=
CERNIQ_VAULT_AUDIT_TRANSIT_NAME=
CERNIQ_VAULT_AUDIT_VERSION=
CERNIQ_VAULT_AUDIT_PUB=


# ── Crypto: webhook secret-at-rest ──────────────────────────── REQUIRED-PROD
# 32-byte AES-256-GCM data encryption key (base64). Wraps every
# `WebhookSubscription.secret` so a DB-only compromise cannot forge HMACs.
# Generate:  openssl rand -base64 32
# Production: REQUIRED — boot fails-loud if absent.
# Dev: optional — cipher logs an ephemeral DEK on first use.
CERNIQ_WEBHOOK_SECRET_DEK_B64=


# ── Auth: API key bcrypt ──────────────────────────────────────────────── DEV-OK
# 12 in production, 4 in tests/CI for speed.
API_KEY_BCRYPT_COST=12


# ── Auth: federated identity (Auth0 / Clerk / WorkOS) ────────────── OPTIONAL
# Auth0 ADR-0009 bridge. Issuer matches Auth0 `iss` claim shape.
AUTH0_ISSUER=
AUTH0_AUDIENCE=
AUTH0_ACTION_SECRET=
# Set to 'true' to require an Auth0 session before serving the dashboard.
# Defaults to permitting all requests in dev so local development works
# without an Auth0 tenant.
AUTH0_REQUIRED=false


# ── Auth: WorkOS IdP adapter (ADR-0009-B, OD-015 swap option) ────── OPTIONAL
# Third `IdpAdapter` implementation. Auth0 remains the default (OD-015);
# WorkOS is a drop-in swap for shops standardized on it. The provider
# factory (idp-workos.module.ts) throws if WORKOS_API_KEY is missing AND
# the WorkOS adapter is bound — leave blank unless you wire it.
WORKOS_API_KEY=
WORKOS_COOKIE_PASSWORD=


# ── Onboarding: admin backfill gate ──────────────────────────────── OPTIONAL
# Shared-secret that authorizes the admin onboarding endpoints
# (`POST /v1/onboarding/admin/backfill`, `GET .../last`) via the
# `X-CERNIQ-Admin` request header. Read directly from process.env by
# onboarding.controller.ts (NOT through the Zod config). FAIL-CLOSED: when
# unset, the admin endpoints reject every request (403 admin_token_invalid).
# Set it (and pass it as the header) to drive `cerniq-cli onboarding backfill`.
CERNIQ_ADMIN_TOKEN=
# Cron expression for the periodic onboarding backfill pass. Read at
# decorator-eval time (@Cron) so it must be a raw env, not Zod config.
# Default when unset: every 5 minutes.
CERNIQ_ONBOARDING_BACKFILL_CRON=*/5 * * * *


# ── Compliance: audit retention sweep ─────────────────────────────── OPTIONAL
# Interval (ms) between audit-retention sweep passes in
# audit-retention.service.ts (read directly via process.env). Retention
# HORIZON (per-tier days) is owned by plans.ts; this only tunes cadence.
CERNIQ_AUDIT_RETENTION_INTERVAL_MS=


# ── Rate limits ──────────────────────────────────────────────────────── DEV-OK
# Per-minute caps (nest-throttler). Tune per plan tier in production.
THROTTLE_VERIFY_PER_MIN=1000
THROTTLE_DEFAULT_PER_MIN=120


# ── Feature flags ────────────────────────────────────────────────────── DEV-OK
ENABLE_BATE=true
ENABLE_WEBHOOKS=true
ENABLE_SWAGGER=true
# Require DPoP proof on every /v1/verify (RFC 9449). Off by default —
# turn on after rolling out client-side proof generation in the SDK.
CERNIQ_DPOP_REQUIRED=false
# Enable post-quantum hybrid signatures (Ed25519 || ML-DSA-65). Scaffold-
# ready; flip on once your relying parties accept the larger sig payloads.
CERNIQ_HYBRID_PQ_ENABLED=false
# Comma-separated list. Default is the in-process builtin engine.
# Add 'cedar' or 'opa' once the corresponding WASM artifact is shipping.
CERNIQ_POLICY_ENGINES=builtin


# ── Observability: tracing (OpenTelemetry) ─────────────────────────── OPTIONAL
# When CERNIQ_OTEL_ENABLED=true, the API emits W3C-compatible spans for the
# verify hot path, audit chain, KMS round-trips, and policy engine eval.
CERNIQ_OTEL_ENABLED=false
CERNIQ_OTEL_SERVICE_NAME=cerniq-api
# Exporter: 'otlp-http' (production) | 'console' (debug) | 'noop'
CERNIQ_OTEL_EXPORTER=otlp-http
# Standard OTel envs honored by the SDK:
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_RESOURCE_ATTRIBUTES=
# Optional: stamp deployment region on every span (e.g. us-east-1, eu-west-1).
CERNIQ_REGION=


# ── Observability: errors + metrics ──────────────────────────────── OPTIONAL
# Sentry DSN — leave blank to disable error reporting.
SENTRY_DSN=


# ── Build identity (CI/release pipeline only) ─────────────────────── OPTIONAL
# Surfaced at GET /health/version for blue-green confirmation.
CERNIQ_VERSION=
GIT_SHA=
BUILD_AT=


# ── Stripe billing (Phase 1 — M-011) ──────────────────────────────── OPTIONAL
# When STRIPE_SECRET_KEY is unset, BillingService is a no-op (manual
# planTier admin still works). When set, STRIPE_SECRET_KEY +
# STRIPE_WEBHOOK_SECRET + the three redirect URLs are required at boot;
# each price id is required only for the tier you actually sell.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Per-tier price ids from the Stripe dashboard. The var SUFFIX must match
# `PlanDefinition.stripeEnvSuffix` resolution in stripe.service.ts. The
# code today reads EXACTLY these three (see config.service.ts getters):
#
#   STRIPE_PRICE_DEVELOPER  → Developer  ($49/mo,  50K verifies)
#   STRIPE_PRICE_GROWTH     → Team       ($299/mo, 500K verifies)
#   STRIPE_PRICE_ENTERPRISE → Enterprise (custom, invoiced)
#
# NAMING (ADR-0014): "Team" is the display name for the GROWTH tier — the
# Prisma `PlanTier` enum value stays GROWTH until the Round-18 enum
# migration, so the env var is STRIPE_PRICE_GROWTH (NOT _TEAM — _TEAM is
# silently dropped by the Zod config). ADR-0014 also specced a SCALE tier
# ($1,499/mo, 5M verifies); it is NOT yet wired in plans.ts, so there is
# no STRIPE_PRICE_SCALE the code reads. Setting one has no effect until
# the tier ships (tracked as a remaining gap — see CREDENTIALS_BOOTSTRAP §2.1).
STRIPE_PRICE_DEVELOPER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=
# Optional metered usage product (per-verify overage, $0.0008 uniform
# across paid tiers). When set, usage records are reported to Stripe.
# Leave blank to hard-stop at tier cap with no overage.
STRIPE_PRICE_OVERAGE_VERIFY=
# Where Stripe-hosted Checkout / Customer Portal redirect after the user
# finishes (or cancels) the flow. Required when STRIPE_SECRET_KEY is set.
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=
STRIPE_PORTAL_RETURN_URL=


# ── Dashboard ─────────────────────────────────────────────────────────── DEV-OK
# Phase 1 dashboard is server-rendered and reads the API server-side. It
# uses an operator-pinned API key until per-user Auth0 sessions land (M-020).
#
# CERNIQ_API_BASE_URL is the single server-side API base for ALL dashboard
# calls (pricing SSR, agents, mcp-servers, billing portal, api-client).
# Set it without a trailing /v1/ — consumers add the version prefix.
# Defaults to http://localhost:4000 when unset.
CERNIQ_API_BASE_URL=
# NOTE: NEXT_PUBLIC_API_URL is currently NOT read by any dashboard code
# (reserved for future client-component fetches). Setting it has no effect
# today — server-side calls go through CERNIQ_API_BASE_URL above.
NEXT_PUBLIC_API_URL=http://localhost:4000
CERNIQ_DASHBOARD_API_KEY=
CERNIQ_DASHBOARD_PRINCIPAL_ID=
# Placeholder identity shown by the dashboard until Auth0 sessions land.
# Defaults to developer@local when unset.
CERNIQ_DASHBOARD_EMAIL=


# ── Docs site (apps/docs — fumadocs) ──────────────────────────────── OPTIONAL
# Canonical base URL for metadata, sitemap, robots, and llms.txt.
# Defaults to https://docs.cerniq.io when unset (see OD-022 deploy timing).
NEXT_PUBLIC_DOCS_URL=


# ── Client packages: CLI / MCP server / MCP bridge ────────────────── OPTIONAL
# These are CONSUMER-side env vars (agents, relying parties, operator CLI),
# not API-server config. Use them to point local test clients at your
# dev/stage control plane.
#   CERNIQ_API_KEY     — CLI + MCP server credential (CLI/MCP throw if absent)
#   CERNIQ_BASE_URL    — CLI + MCP server API base (default https://api.cerniq.dev)
#   CERNIQ_VERIFY_KEY  — relying-party verify key consumed by @cerniq/mcp-bridge
CERNIQ_API_KEY=
CERNIQ_BASE_URL=
CERNIQ_VERIFY_KEY=
