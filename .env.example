# ============================================================
# AEGIS — Local development environment
# Copy to `.env` and adjust per environment
# ============================================================

# ── Runtime ─────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug
API_BASE_URL=http://localhost:4000

# ── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://aegis:aegis@localhost:5432/aegis?schema=public

# ── Cache / queue ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Crypto ──────────────────────────────────────────────────
# Per CLAUDE.md "one curve, one library" — every signing primitive is Ed25519.
# Generate keypairs locally with the SDK:
#
#   node -e "import('@aegis/sdk').then(({ generateKeypair }) => generateKeypair().then(console.log))"
#
# Each environment (dev / staging / prod) MUST have its own keypair. Never
# reuse a dev key in prod.

# Audit-event chain signing key (separation of duties from policy signing).
AUDIT_ED25519_PRIVATE_KEY_B64=
AUDIT_ED25519_PUBLIC_KEY_B64=

# AEGIS service signing key for policy capability tokens.
JWT_ED25519_PRIVATE_KEY_B64=
JWT_ED25519_PUBLIC_KEY_B64=

# DEPRECATED — RSA path superseded by AUDIT_ED25519_*. Kept for one release.
AUDIT_SIGNING_KEY_B64=

# ── Auth ────────────────────────────────────────────────────
# Bcrypt cost for API key hashing (12 in production, 4 in tests).
API_KEY_BCRYPT_COST=12

# ── Rate limits ─────────────────────────────────────────────
THROTTLE_VERIFY_PER_MIN=1000
THROTTLE_DEFAULT_PER_MIN=120

# ── Feature flags ───────────────────────────────────────────
ENABLE_BATE=true
ENABLE_WEBHOOKS=true
ENABLE_SWAGGER=true

# ── Observability ───────────────────────────────────────────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Stripe (Phase 1 billing) ────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Dashboard ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
