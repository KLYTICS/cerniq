# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
out/
.next/
.turbo/
.tsbuildinfo
*.tsbuildinfo

# Env / secrets
.env
.env.*
!.env.example
.envrc

# Test coverage
coverage/
.nyc_output/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Editors
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.swp
.DS_Store

# Prisma
apps/api/prisma/migrations/dev.db*

# Local artifacts
.cache/
tmp/
*.local

# Dev seed artifacts (scripts/seed-dev.ts) — both copies of the agent
# private key. NEVER commit; rotate via `pnpm seed:dev -- --reset`.
.aegis-dev-key.txt
.local/keys/

# Local test result artifacts — bring-up captures, k6 output, e2e traces.
# Often contain rotating API keys / token material; never commit.
tests/results/
**/perf-baseline.json.local

# Spec-drift report — written by apps/api/scripts/check-openapi-prisma-parity.ts
# on drift detection (exit 1). Embeds absolute local paths (REPO_ROOT-prefixed
# prismaPath / specPath) so it's machine-specific by construction. The drift
# gate is the script's exit code; the JSON exists for debugging.
spec-sync.json

# Per-session Claude state — settings.local.json + claude/worktrees/* used by
# parallel Claude sessions for coordination. None of it is portable.
.claude/

# Per-session Codex/OMX state — logs/, metrics.json, state/. Same reasoning
# as .claude/ — local-only session telemetry, not source.
.omx/
