{
  "mcpServers": {
    "your-svc-via-cerniq": {
      "command": "pnpm",
      "args": ["tsx", "/path/to/cerniq/examples/ai-platform-tool-call/src/mcp-server.ts"],
      "env": {
        "CERNIQ_API_BASE": "https://api.cerniq.io",
        "CERNIQ_VERIFY_KEY": "cerniq_vk_REPLACE_ME",
        "DOWNSTREAM_API_BASE": "https://api.your-svc.example.com",
        "MIN_TRUST_SCORE": "600"
      }
    }
  }
}
