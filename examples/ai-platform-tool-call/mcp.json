{
  "mcpServers": {
    "your-svc-via-okoro": {
      "command": "pnpm",
      "args": ["tsx", "/path/to/okoro/examples/ai-platform-tool-call/src/mcp-server.ts"],
      "env": {
        "OKORO_API_BASE": "https://api.okoroapp.com",
        "OKORO_VERIFY_KEY": "okoro_vk_REPLACE_ME",
        "DOWNSTREAM_API_BASE": "https://api.your-svc.example.com",
        "MIN_TRUST_SCORE": "600"
      }
    }
  }
}
