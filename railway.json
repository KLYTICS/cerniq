{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile && pnpm --filter @cerniq/api prisma:generate && pnpm --filter @cerniq/api build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @cerniq/api start:prod",
    "healthcheckPath": "/v1/health/ready",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
