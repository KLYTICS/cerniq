{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../packages/tsconfig/library.json",
  "compilerOptions": {
    "outDir": "dist",
    "noEmit": true,
    "types": ["node", "vitest/globals"],
    "resolveJsonModule": true,
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "target": "ES2022",
    "baseUrl": ".",
    "paths": {
      "@cerniq/sdk": ["../packages/sdk-ts/src/index.ts"],
      "@cerniq/types": ["../packages/types/src/index.ts"]
    }
  },
  "include": ["e2e/**/*.ts", "load/**/*.ts", "vitest.config.ts"],
  "exclude": ["node_modules", "dist"]
}
