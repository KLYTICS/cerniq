{
  "name": "@aegis/e2e",
  "version": "0.1.0",
  "private": true,
  "description": "AEGIS — black-box end-to-end test harness. Drives the live API over HTTP using @aegis/sdk + @aegis/types.",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "test": "vitest run --root .",
    "test:watch": "vitest --root .",
    "typecheck": "tsc --noEmit",
    "load": "k6 run load/verify.js"
  },
  "dependencies": {
    "@aegis/sdk": "link:../packages/sdk-ts",
    "@aegis/types": "link:../packages/types"
  },
  "devDependencies": {
    "@aegis/tsconfig": "link:../packages/tsconfig",
    "@types/node": "^20.14.0",
    "fast-check": "^3.23.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
