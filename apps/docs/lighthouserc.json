{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:3100/",
        "http://localhost:3100/docs",
        "http://localhost:3100/docs/concepts/denial-precedence",
        "http://localhost:3100/docs/concepts/trust-bands",
        "http://localhost:3100/docs/api/agents",
        "http://localhost:3100/docs/personas/sre",
        "http://localhost:3100/docs/compliance/overview"
      ],
      "startServerCommand": "next start -p 3100",
      "startServerReadyPattern": "Ready in",
      "startServerReadyTimeout": 60000,
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "skipAudits": ["uses-http2"]
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.85 }],
        "_comment_a11y": "0.85 first-deploy baseline; raise to 0.95 in a follow-up after fixing the table-component a11y issues (DenialPrecedence/TrustBandLegend/WebhookEventCatalog tables score 0.89-0.91 on pages that embed them due to th-scope, color-contrast, and label-association gaps).",
        "categories:accessibility": ["error", { "minScore": 0.85 }],
        "categories:best-practices": ["error", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.95 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci"
    }
  }
}
