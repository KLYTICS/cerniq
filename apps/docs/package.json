{
  "name": "@cerniq/docs",
  "version": "0.1.0",
  "private": true,
  "description": "Live documentation site for CERNIQ. Next.js 16 + Fumadocs.",
  "scripts": {
    "predev": "node scripts/generate-api-docs.mjs && node scripts/generate-sdk-docs.mjs",
    "dev": "next dev -p 3100",
    "prebuild": "node scripts/generate-api-docs.mjs && node scripts/generate-sdk-docs.mjs",
    "build": "next build",
    "start": "next start -p 3100",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "openapi:generate": "node scripts/generate-api-docs.mjs",
    "sdk:generate": "node scripts/generate-sdk-docs.mjs",
    "lhci:autorun": "lhci autorun"
  },
  "dependencies": {
    "@cerniq/types": "workspace:*",
    "fumadocs-core": "^14.6.0",
    "fumadocs-mdx": "^11.3.0",
    "fumadocs-openapi": "^5.5.0",
    "fumadocs-ui": "^14.6.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typedoc": "^0.27.0",
    "typedoc-plugin-markdown": "^4.3.0",
    "typescript": "^5.6.3"
  }
}
