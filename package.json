{
  "name": "aegis",
  "version": "0.1.0",
  "private": true,
  "description": "AEGIS — Agent Gateway & Identity Stack. Neutral cryptographic identity, policy enforcement, behavioral attestation, and audit rails for AI agents.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KLYTICS/aegis.git"
  },
  "homepage": "https://github.com/KLYTICS/aegis#readme",
  "bugs": {
    "url": "https://github.com/KLYTICS/aegis/issues"
  },
  "author": "KLYTICS LLC <ops@klytics.io>",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @aegis/api dev",
    "dev:dashboard": "pnpm --filter @aegis/dashboard dev",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @aegis/api prisma:migrate",
    "db:generate": "pnpm --filter @aegis/api prisma:generate",
    "db:reset": "pnpm --filter @aegis/api prisma:reset",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm --filter @aegis/api test:e2e",
    "test:parity": "pnpm --filter @aegis/e2e run test:parity",
    "test:cross-package": "pnpm test:parity",
    "doctor": "pnpm --filter @aegis/scripts run doctor",
    "doctor:full": "pnpm --filter @aegis/scripts run doctor:full",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "clean": "pnpm -r exec rm -rf dist .next .turbo node_modules/.cache",
    "seed:dev": "pnpm --filter @aegis/scripts seed",
    "gen:error-catalog": "pnpm -F @aegis/types exec tsx ../../scripts/generate-error-catalog.ts",
    "gen:denial-reason": "pnpm -F @aegis/scripts exec tsx ./generate-denial-reason.ts",
    "check:openapi-zod": "pnpm -F @aegis/types exec tsx scripts/check-openapi-zod-parity.ts",
    "check:openapi-prisma": "pnpm -F @aegis/api exec tsx scripts/check-openapi-prisma-parity.ts",
    "check:migrations": "pnpm -F @aegis/scripts exec tsx check-migration-immutability.ts",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm check:openapi-zod && pnpm check:openapi-prisma && pnpm check:migrations"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "undici@<6.24.0": ">=6.24.0",
      "lodash@<4.17.24": ">=4.17.24",
      "fast-uri@<=3.1.1": ">=3.1.2",
      "hono@<4.12.18": ">=4.12.18",
      "postcss@<8.5.10": ">=8.5.10",
      "ip-address@<=10.1.0": ">=10.1.1",
      "js-yaml@<4.1.1": ">=4.1.1",
      "qs@<=6.14.1": ">=6.14.2",
      "cookie@<0.7.0": ">=0.7.0",
      "vite@<=6.4.1": ">=6.4.2",
      "esbuild@<=0.24.2": ">=0.25.0"
    }
  }
}
