{
  "name": "cerniq",
  "version": "0.1.0",
  "private": true,
  "description": "CERNIQ — Agent Gateway & Identity Stack. Neutral cryptographic identity, policy enforcement, behavioral attestation, and audit rails for AI agents.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KLYTICS/cerniq.git"
  },
  "homepage": "https://github.com/KLYTICS/cerniq#readme",
  "bugs": {
    "url": "https://github.com/KLYTICS/cerniq/issues"
  },
  "author": "KLYTICS LLC <ops@klytics.io>",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @cerniq/api dev",
    "dev:dashboard": "pnpm --filter @cerniq/dashboard dev",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:migrate": "pnpm --filter @cerniq/api prisma:migrate",
    "db:generate": "pnpm --filter @cerniq/api prisma:generate",
    "db:reset": "pnpm --filter @cerniq/api prisma:reset",
    "test": "pnpm -r run test",
    "test:e2e": "pnpm --filter @cerniq/api test:e2e",
    "test:parity": "pnpm --filter @cerniq/e2e run test:parity",
    "test:cross-package": "pnpm test:parity",
    "doctor": "pnpm --filter @cerniq/scripts run doctor",
    "doctor:full": "pnpm --filter @cerniq/scripts run doctor:full",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "clean": "pnpm -r exec rm -rf dist .next .turbo node_modules/.cache",
    "seed:dev": "pnpm --filter @cerniq/scripts seed",
    "gen:error-catalog": "pnpm -F @cerniq/types exec tsx ../../scripts/generate-error-catalog.ts",
    "gen:denial-reason": "pnpm -F @cerniq/scripts exec tsx ./generate-denial-reason.ts",
    "check:openapi-zod": "pnpm -F @cerniq/types exec tsx scripts/check-openapi-zod-parity.ts",
    "check:openapi-prisma": "pnpm -F @cerniq/api exec tsx scripts/check-openapi-prisma-parity.ts",
    "check:migrations": "pnpm -F @cerniq/scripts exec tsx check-migration-immutability.ts",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm check:openapi-zod && pnpm check:openapi-prisma && pnpm check:migrations"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.13.0",
    "@types/node": "^20.14.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-security": "^3.0.1",
    "eslint-plugin-unicorn": "^56.0.0",
    "lint-staged": "^17.0.5",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.0"
  },
  "pnpm": {
    "overrides": {
      "next": ">=16.2.6",
      "hono": ">=4.12.18",
      "undici": ">=6.21.2",
      "lodash": ">=4.18.0",
      "fast-uri": ">=3.1.2",
      "qs": ">=6.15.2",
      "ws": ">=8.20.1",
      "cookie": ">=0.7.0",
      "tmp": ">=0.2.4",
      "js-yaml": ">=4.1.1",
      "uuid": ">=11.0.3",
      "brace-expansion": ">=2.0.2 <3.0.0",
      "minimatch>brace-expansion": ">=5.0.6",
      "ip-address": ">=10.1.1",
      "protobufjs": ">=7.5.8",
      "esbuild": ">=0.25.0",
      "vite": ">=6.4.2",
      "postcss": ">=8.5.10",
      "express-rate-limit": ">=8.5.2"
    }
  }
}
