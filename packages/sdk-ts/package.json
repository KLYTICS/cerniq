{
  "name": "@aegis/sdk",
  "version": "0.1.0",
  "description": "AEGIS — Agent Gateway & Identity Stack — TypeScript SDK. Cryptographic identity, scoped policies, and verification for AI agents.",
  "license": "MIT",
  "author": "AEGIS Labs <hello@aegislabs.io>",
  "homepage": "https://aegislabs.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klytics/aegis.git",
    "directory": "packages/sdk-ts"
  },
  "bugs": {
    "url": "https://github.com/klytics/aegis/issues"
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "dev": "tsup --watch",
    "test": "jest",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aegis/types": "workspace:*",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.13",
    "@types/node": "^20.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["aegis", "agent", "identity", "verification", "ai-agent", "auth", "ed25519", "trust-score"]
}
