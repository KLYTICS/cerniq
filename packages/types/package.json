{
  "name": "@cerniq/types",
  "version": "0.1.0",
  "description": "Shared API contract types and Zod schemas for CERNIQ — single source of truth across API, SDK, and dashboard.",
  "license": "MIT",
  "author": "CERNIQ Labs <hello@cerniqapp.com>",
  "homepage": "https://cerniqapp.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klytics/cerniq.git",
    "directory": "packages/types"
  },
  "bugs": {
    "url": "https://github.com/klytics/cerniq/issues"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "keywords": [
    "cerniq",
    "agent-identity",
    "zod",
    "schemas",
    "types",
    "api-contract"
  ],
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "dev": "tsup --watch",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "spec-sync": "tsx scripts/check-openapi-zod-parity.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cerniq/tsconfig": "workspace:*",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "yaml": "^2.6.1"
  }
}
