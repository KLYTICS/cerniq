{
  "name": "@cerniq/cli",
  "version": "0.1.0",
  "description": "CERNIQ operator CLI — manage agents, policies, KMS, audit, and MCP from the terminal.",
  "type": "module",
  "license": "MIT",
  "author": "CERNIQ Labs <hello@cerniq.io>",
  "homepage": "https://cerniq.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klytics/cerniq.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/klytics/cerniq/issues"
  },
  "keywords": [
    "cerniq",
    "agent",
    "identity",
    "cli",
    "operator",
    "policy",
    "audit"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cerniq": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cerniq/sdk": "workspace:*",
    "@cerniq/types": "workspace:*",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0",
    "commander": "^12.1.0",
    "kleur": "^4.1.5",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@cerniq/tsconfig": "workspace:*",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
