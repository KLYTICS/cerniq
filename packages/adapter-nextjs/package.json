{
  "name": "@aegis/adapter-nextjs",
  "version": "0.1.0",
  "description": "Drop-in AEGIS verification helpers for Next.js — App Router, Pages Router, and middleware.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js",
      "require": "./dist/middleware.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/middleware.ts --format esm,cjs --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@aegis/sdk": "workspace:*",
    "next": ">=14",
    "react": ">=18"
  },
  "devDependencies": {
    "@aegis/sdk": "workspace:*",
    "@types/node": "^20.14.0",
    "@types/react": "^19.0.0",
    "next": "^16.0.0",
    "react": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "keywords": [
    "aegis",
    "nextjs",
    "agent-identity",
    "verify",
    "middleware",
    "adapter"
  ]
}
