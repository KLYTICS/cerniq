{
  "name": "@okoro/audit-verifier",
  "version": "0.1.0",
  "description": "Offline verifier for OKORO audit chains. Anyone with the public JWKS can independently verify the tamper-evidence of an OKORO audit log export.",
  "license": "MIT",
  "author": "OKORO Labs <hello@okoroapp.com>",
  "homepage": "https://okoroapp.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klytics/okoro.git",
    "directory": "packages/audit-verifier"
  },
  "bugs": {
    "url": "https://github.com/klytics/okoro/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "okoro-audit-verify": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup && pnpm build:dts",
    "build:dts": "tsc --emitDeclarationOnly --outDir dist && node -e \"require('fs').copyFileSync('dist/index.d.ts','dist/index.d.cts');require('fs').copyFileSync('dist/cli.d.ts','dist/cli.d.cts')\"",
    "prepublishOnly": "pnpm build",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.5.0"
  },
  "devDependencies": {
    "@okoro/tsconfig": "workspace:*",
    "@types/node": "^20.14.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "keywords": [
    "okoro",
    "audit",
    "tamper-evident",
    "ed25519",
    "soc2",
    "jwks",
    "compliance"
  ]
}
