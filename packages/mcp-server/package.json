{
  "name": "@cerniq/mcp-server",
  "version": "0.1.0",
  "description": "CERNIQ exposed as an MCP server. Lets Claude Desktop / Cursor / any MCP host call CERNIQ verify, agents, policies, and audit tools natively.",
  "type": "module",
  "license": "MIT",
  "author": "CERNIQ Labs <hello@cerniq.io>",
  "homepage": "https://cerniq.io/mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klytics/cerniq.git",
    "directory": "packages/mcp-server"
  },
  "bugs": {
    "url": "https://github.com/klytics/cerniq/issues"
  },
  "keywords": [
    "cerniq",
    "mcp",
    "model-context-protocol",
    "claude-desktop",
    "cursor",
    "agent-identity",
    "verification"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "cerniq-mcp": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cerniq/sdk": "workspace:*",
    "@cerniq/types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cerniq/tsconfig": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
