{
  "name": "@cerniq/mcp-bridge",
  "version": "0.1.0",
  "description": "CERNIQ verification middleware for any MCP (Model Context Protocol) server. Wraps an MCP transport so every tool call carries a verified CERNIQ agent identity.",
  "license": "MIT",
  "author": "CERNIQ Labs <hello@cerniqapp.com>",
  "homepage": "https://cerniqapp.com/mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klytics/cerniq.git",
    "directory": "packages/mcp-bridge"
  },
  "bugs": {
    "url": "https://github.com/klytics/cerniq/issues"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "keywords": [
    "cerniq",
    "mcp",
    "model-context-protocol",
    "agent-identity",
    "agent-verification",
    "trust-score"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build",
    "dev": "tsup --watch",
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@cerniq/sdk": "workspace:*",
    "@cerniq/types": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@cerniq/tsconfig": "workspace:*",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
